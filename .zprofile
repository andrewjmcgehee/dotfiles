# Path
export PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.local/bin:$HOME/Workspaces/go/bin:/usr/local/texlive/2022/bin/universal-darwin

# Variables
export EDITOR="nvim"
export HISTFILE="$HOME/.config/zsh/.zsh_history"
export VISUAL="nvim"
export ZDOTDIR="$HOME/.config/zsh"

# Keep HOME clean
export GOPATH="$HOME/Workspaces/go"
export LESS=-R
export LESSHISTFILE="-"
